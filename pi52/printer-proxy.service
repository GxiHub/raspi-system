[Unit]
Description=UberEats Printer Proxy
After=network.target

[Service]
ExecStart=/usr/bin/python3 -u /home/pi52/proxy.py
WorkingDirectory=/home/pi52
Restart=always
RestartSec=5
User=pi52
StandardOutput=append:/home/pi52/proxy.log
StandardError=append:/home/pi52/proxy.log

[Install]
WantedBy=multi-user.target
